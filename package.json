{
  "name": "worktree-manager",
  "version": "0.1.1",
  "productName": "Worktree Manager",
  "description": "A desktop productivity app for managing Git worktrees.",
  "author": "hyjoong",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm dev:electron",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "pnpm build:node && concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"node --watch scripts/build-preload.mjs\" \"wait-on tcp:5173 dist/main/index.js dist/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist/main --watch dist/preload --ext js --exec \\\"electron .\\\"\"",
    "build:node": "tsc -p tsconfig.node.json && node scripts/build-main.mjs && node scripts/build-preload.mjs",
    "build": "pnpm build:node && vite build",
    "icon:mac": "swift scripts/generate-mac-icon.swift assets/icon-source.png build/icon.icns",
    "dist": "node scripts/package.mjs",
    "dist:dir": "node scripts/package.mjs --dir",
    "dist:mac": "node scripts/package.mjs --mac",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.6.0",
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.0"
  }
}
